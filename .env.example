# Supabase (frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-side / Netlify functions only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude AI (server-side only)
CLAUDE_API_KEY=sk-ant-...

# AWS SES (use SES_ prefix — AWS_ is reserved by Netlify)
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_REGION=us-east-1
AWS_SES_FROM_ADDRESS=noreply@harborview-consulting.com

# GitHub (for proposal repo commits)
GITHUB_TOKEN=ghp_...
GITHUB_PROPOSAL_REPO=Harbor-View/Harbor-View-Consulting-Proposal-System

# HubSpot
VITE_HUBSPOT_MEETING_URL=https://meetings.hubspot.com/your-link

# Internal
HV_NOTIFICATION_EMAIL=mmolloy@harborview-consulting.com
